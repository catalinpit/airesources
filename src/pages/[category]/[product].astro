---
import '../../styles/global.css';
import Layout from '../../layouts/layout.astro';
import Button from '../../components/ui/Button.astro';
import Tag from '../../components/ui/Tag.astro';
import Divider from '../../components/ui/Divider.astro';
import SponsoredProducts from '../../components/ui/Sponsored-Products.astro';
import PromptIcon from '../../components/icons/PromptIcon.astro';
import SkillIcon from '../../components/icons/SkillIcon.astro';
import DocumentIcon from '../../components/icons/DocumentIcon.astro';
import CopyIcon from '../../components/icons/CopyIcon.astro';
import CheckIcon from '../../components/icons/CheckIcon.astro';
import ExternalLinkIcon from '../../components/icons/ExternalLinkIcon.astro';
import EyeIcon from '../../components/icons/EyeIcon.astro';
import DollarIcon from '../../components/icons/DollarIcon.astro';
import InfoIcon from '../../components/icons/InfoIcon.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  const resources = await getCollection('resources');

  return resources.map(resource => {
    const category = categories.find(c => c.data.categorySlug === resource.data.categorySlug);

    return {
      params: {
        category: resource.data.categorySlug,
        product: resource.data.name.toLowerCase().replace(/\s+/g, '-'),
      },
      props: {
        category: category?.data,
        item: resource.data,
      },
    };
  });
}

const { category, item } = Astro.props;

const siteUrl = Astro.site || 'https://airesources.dev';
const productUrl = new URL(`/${category.categorySlug}/${item.name.toLowerCase().replace(/\s+/g, '-')}/`, siteUrl).href;
const categoryUrl = new URL(`/category/${category.categorySlug}/`, siteUrl).href;

const tags = [
  { label: item.type || 'tool', href: '#' },
];

const allResources = await getCollection('resources');
const allItems = allResources.map(r => ({
  ...r.data,
  categorySlug: r.data.categorySlug
}));

const filteredItems = allItems.filter(product =>
  product.name !== item.name || product.categorySlug !== category.categorySlug
);

const reusableContent = item.skill || item.prompt;
const reusableContentLabel = item.skill ? 'Skill' : 'Prompt';
const reusableContentAccent = item.skill ? 'text-emerald-400' : 'text-indigo-500';
---

<Layout description={item.description} pageTitle={item.name}>
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "SoftwareApplication",
		"name": item.name,
		"description": item.description,
		...(item.link && { "url": item.link }),
		"applicationCategory": category.title,
		"operatingSystem": "Web",
		"offers": item.pricing ? {
			"@type": "Offer",
			"priceCurrency": "USD",
			"price": item.pricing.type === "free" ? "0" : undefined,
			"priceSpecification": item.pricing.tiers?.map(tier => ({
				"@type": "UnitPriceSpecification",
				"name": tier.name,
				"price": tier.price
			}))
		} : undefined,
		"breadcrumb": {
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "Resources",
					"item": siteUrl
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": category.title,
					"item": categoryUrl
				},
				{
					"@type": "ListItem",
					"position": 3,
					"name": item.name,
					"item": productUrl
				}
			]
		}
	})} />
  <div class="relative isolate min-h-screen overflow-hidden bg-[#090a0f] text-white">
    <div class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,rgba(129,140,248,0.08)_0%,transparent_22rem)]"></div>
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <nav class="mx-auto mb-6 max-w-3xl" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2 text-sm text-neutral-400" itemscope itemtype="https://schema.org/BreadcrumbList">
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="/" class="transition-colors hover:text-white" itemprop="item">
            <span itemprop="name">Resources</span>
          </a>
          <meta itemprop="position" content="1" />
        </li>
        <span aria-hidden="true">/</span>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href={`/category/${category.categorySlug}/`} class="transition-colors hover:text-white" itemprop="item">
            <span itemprop="name">{category.title}</span>
          </a>
          <meta itemprop="position" content="2" />
        </li>
        <span aria-hidden="true">/</span>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <span class="font-medium text-white" itemprop="name" aria-current="page">{item.name}</span>
          <meta itemprop="position" content="3" />
        </li>
      </ol>
    </nav>

    {filteredItems.length > 0 && <SponsoredProducts items={filteredItems} class="max-w-3xl mx-auto" />}

    <main>
      <div class="max-w-3xl mx-auto">
        <div class="rounded-lg border border-white/10 bg-[#10131b] shadow-[0_24px_80px_rgba(0,0,0,0.24)]">
          <div class="p-6 md:p-8">
            <div class="mb-8 flex items-start gap-4">
              <div class="flex-shrink-0">
                <div class="h-14 w-14 rounded-lg border border-white/10 bg-black/25 p-2.5">
                  {item.skill ? (
                    <SkillIcon class="w-full h-full text-emerald-400" />
                  ) : item.prompt ? (
                    <PromptIcon class="w-full h-full text-indigo-500" />
                  ) : item.iconUrl ? (
                  <img
                    src={item.iconUrl}
                    alt={`${item.name} icon`}
                    class="w-full h-full rounded-lg object-contain icon-with-fallback"
                    data-fallback-letter={item.name.charAt(0).toUpperCase()}
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                  />
                  <span class="hidden w-full h-full rounded-lg bg-white items-center justify-center text-neutral-950 font-bold text-xl">{item.name.charAt(0).toUpperCase()}</span>
                  ) : (
                  <span class="flex w-full h-full rounded-lg bg-white items-center justify-center text-neutral-950 font-bold text-xl">{item.name.charAt(0).toUpperCase()}</span>
                  )}
                </div>
              </div>
              <div class="min-w-0">
                <p class="mb-2 font-mono text-xs uppercase tracking-[0.18em] text-neutral-400">
                  /{category.title}
                </p>
                <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
                  {item.name}
                </h1>
                <p class="mt-3 text-base leading-7 text-neutral-300">
                  {item.description}
                </p>
              </div>
            </div>

            {reusableContent && (
              <>
                {item.tags && item.tags.length > 0 && (
                  <div class="mb-6">
                    <div class="flex flex-wrap items-center gap-2">
                      {item.tags.map(tag => (
                        <span class="relative inline-flex items-center justify-center rounded-md border border-white/10 bg-white/[0.04] px-2.5 py-1 text-xs text-neutral-300">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  </div>
                )}
                <Divider class="mb-8" />
                <div class="space-y-4">
                  <div class="flex items-center justify-between">
                    <h3 class="flex items-center gap-2 text-lg font-semibold leading-6 tracking-wide text-white">
                      <DocumentIcon class={`w-5 h-5 ${reusableContentAccent}`} />
                      {reusableContentLabel}
                    </h3>
                    <button
                      id="copy-resource-content-btn"
                      type="button"
                      class="inline-flex items-center gap-1.5 rounded-lg border border-white/10 bg-white/[0.04] px-3 py-1.5 text-sm font-medium text-neutral-300 transition-colors hover:border-indigo-300/40 hover:text-white"
                      title={`Copy ${reusableContentLabel.toLowerCase()} to clipboard`}
                    >
                      <CopyIcon id="copy-icon" class="w-4 h-4" />
                      <CheckIcon id="check-icon" class="w-4 h-4 hidden" />
                      <span id="copy-text">Copy</span>
                    </button>
                  </div>
                  <div
                    id="resource-content"
                    class="rounded-lg border border-white/10 bg-black/25 p-6 font-mono text-sm text-neutral-200 whitespace-pre-line"
                  >
                    {reusableContent}
                  </div>
                  {item.example && (
                    <div class="mt-6">
                      <h3 class="flex items-center gap-2 text-lg font-semibold leading-6 tracking-wide text-white">
                        <DocumentIcon class="w-5 h-5 text-indigo-500" />
                        Usage Example
                      </h3>
                      <div
                        class="example-content mt-4 rounded-lg border border-indigo-300/20 bg-indigo-400/10 p-6 font-mono text-sm text-neutral-200 whitespace-pre-line"
                      >
                        {item.example}
                      </div>
                    </div>
                  )}
                  {(item.author || item.link) && (
                    <div class="mt-8 space-y-4 border-t border-white/10 pt-8">
                      {item.author && (
                        <div class="flex items-center gap-3">
                          {item.author.iconUrl && (
                            <img
                              src={item.author.iconUrl}
                              alt={`${item.author.name} avatar`}
                              class="w-10 h-10 rounded-full ring-2 ring-white/10"
                            />
                          )}
                          <div>
                            <p class="mb-1 text-xs font-medium uppercase tracking-wide text-neutral-400">Created by</p>
                            <a
                              href={item.author.link}
                              target="_blank"
                              rel="noopener noreferrer"
                            class="group inline-flex items-center gap-1.5 text-base font-semibold text-white transition-colors hover:text-indigo-300"
                            >
                              <span>{item.author.name}</span>
                              <ExternalLinkIcon class="w-4 h-4 opacity-60 group-hover:opacity-100 transition-opacity" />
                            </a>
                          </div>
                        </div>
                      )}
                      {item.link && (
                        <div>
                          <a
                            href={item.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center gap-1.5 text-sm text-indigo-300 transition-colors hover:text-indigo-200"
                          >
                            <ExternalLinkIcon class="w-4 h-4" />
                            View source
                          </a>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              </>
            )}

            {!reusableContent && item.models && item.models.length > 0 && (
              <Divider class="my-8" />
              <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold leading-6 tracking-wide text-white">
                    <EyeIcon class="w-5 h-5 text-indigo-500" />
                    Available Models
                  </h3>
                <div class="flex flex-wrap gap-2">
                  {item.models.map(model => (
                    <span class="relative inline-flex items-center justify-center rounded-md border border-white/10 bg-white/[0.04] px-3 py-1 text-sm text-neutral-300">
                      {model}
                    </span>
                  ))}
                </div>
            )}

            {item.pricing && (
              <div class="space-y-6 mt-8">
                  <h3 class="flex items-center gap-2 text-lg font-semibold leading-6 tracking-wide text-white">
                    <DollarIcon class="w-5 h-5 text-indigo-500" />
                    Pricing
                  </h3>
                    <span class="relative inline-flex items-center justify-center rounded-md border border-white/10 bg-white/[0.04] px-3 py-1 text-sm font-medium text-neutral-300">
                      {item.pricing.type.charAt(0).toUpperCase() + item.pricing.type.slice(1)}
                    </span>
                  <div class="grid gap-3">
                    {item.pricing.tiers.map(tier => (
                      <div class="group relative flex items-center justify-between rounded-lg border border-white/10 bg-black/25 p-4">
                        <div class="flex items-center gap-3">
                          <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-white/10">
                            <DollarIcon class="w-4 h-4 text-indigo-500" />
                          </div>
                          <span class="font-medium text-white">{tier.name}</span>
                        </div>
                        <span class="rounded-md bg-white/10 px-3 py-1.5 text-sm font-semibold text-white">{tier.price}</span>
                      </div>
                    ))}
                  </div>
                  {item.pricing.details && (
                    <div class="flex items-start gap-2.5 rounded-lg p-4 text-sm text-neutral-300">
                      <InfoIcon class="w-4 h-4 mt-0.5 flex-shrink-0 text-indigo-500" />
                      <span>{item.pricing.details}</span>
                    </div>
                  )}
              </div>
            )}

            {!reusableContent && (
            <div class="flex items-center justify-between mt-10">
              <div class="flex flex-wrap gap-2">
                {tags.map(tag => (
                  <Tag href={`/category/${category.categorySlug}/`}>
                    #{tag.label}
                  </Tag>
                ))}
              </div>
              <Button href={item.link} class="inline-flex items-center rounded-lg px-6 py-2.5 font-medium">
                Check out site
                <ExternalLinkIcon class="w-4 h-4 ml-2" />
              </Button>
            </div>
            )}
          </div>
        </div>
      </div>
    </main>
  </div>
  {reusableContent && (
    <script>
      async function writeClipboardText(text: string) {
        await navigator.clipboard.writeText(text);
      }

      const copyBtn = document.getElementById('copy-resource-content-btn');
      const copyIcon = document.getElementById('copy-icon');
      const checkIcon = document.getElementById('check-icon');
      const copyText = document.getElementById('copy-text');
      const resourceContent = document.getElementById('resource-content');

      copyBtn?.addEventListener('click', async () => {
        const text = resourceContent?.textContent || resourceContent?.innerText || '';
        try {
          await writeClipboardText(text);
          copyIcon?.classList.add('hidden');
          checkIcon?.classList.remove('hidden');
          copyText && (copyText.textContent = 'Copied!');
          copyBtn.classList.remove('text-neutral-300');
          copyBtn.classList.add('text-green-400');
          setTimeout(() => {
            copyIcon?.classList.remove('hidden');
            checkIcon?.classList.add('hidden');
            copyText && (copyText.textContent = 'Copy');
            copyBtn.classList.remove('text-green-400');
            copyBtn.classList.add('text-neutral-300');
          }, 2000);
        } catch {
          copyText && (copyText.textContent = 'Failed');
          setTimeout(() => copyText && (copyText.textContent = 'Copy'), 2000);
        }
      });
    </script>
  )}
  </div>
</Layout>
