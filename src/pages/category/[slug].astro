---
import '../../styles/global.css';
import Layout from '../../layouts/layout.astro';
import ResourceCard from '../../components/ui/Resource-Card.astro';
import FilterBar from '../../components/ui/FilterBar.astro';
import SponsoredProducts from '../../components/ui/Sponsored-Products.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = await getCollection('categories');
  const resources = await getCollection('resources');

  return categories.map(category => {
    const categoryItems = resources
      .filter(r => r.data.categorySlug === category.data.categorySlug)
      .map(r => r.data);

    return {
      params: { slug: category.data.categorySlug },
      props: {
        category: category.data,
        items: categoryItems
      }
    };
  });
}

const { category, items } = Astro.props;

const siteUrl = Astro.site || 'https://airesources.dev';
const categoryUrl = new URL(`/category/${category.categorySlug}/`, siteUrl).href;

const allResources = await getCollection('resources');
const allItems = allResources.map(r => ({
  ...r.data,
  categorySlug: r.data.categorySlug
}));

const categoryItems = items.filter(item => !item.sponsored || item.sponsored === "small");

const activeFilters = {
	techStack: [],
	features: [],
	badges: [],
	pricing: [],
	integrations: [],
};
---

<Layout description={category.description} pageTitle={category.title}>
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "CollectionPage",
		"name": category.title,
		"description": category.description,
		"url": categoryUrl,
		"breadcrumb": {
			"@type": "BreadcrumbList",
			"itemListElement": [
				{
					"@type": "ListItem",
					"position": 1,
					"name": "Resources",
					"item": siteUrl
				},
				{
					"@type": "ListItem",
					"position": 2,
					"name": category.title,
					"item": categoryUrl
				}
			]
		},
		"mainEntity": {
			"@type": "ItemList",
			"numberOfItems": categoryItems.length,
			"itemListElement": categoryItems.map((item, index) => ({
				"@type": "ListItem",
				"position": index + 1,
				"item": {
					"@type": "SoftwareApplication",
					"name": item.name,
					"description": item.description,
					"url": new URL(`/${category.categorySlug}/${item.name.toLowerCase().replace(/\s+/g, '-')}/`, siteUrl).href
				}
			}))
		}
	})} />
	<main class="relative isolate min-h-screen overflow-hidden bg-[#090a0f] text-white">
		<div class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,rgba(129,140,248,0.08)_0%,transparent_22rem)]"></div>
		<div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
		<SponsoredProducts items={allItems} class="w-full" />

		<nav class="mb-8" aria-label="Breadcrumb">
			<ol class="flex flex-wrap items-center gap-2 text-sm text-neutral-400" itemscope itemtype="https://schema.org/BreadcrumbList">
				<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
					<a href="/" class="transition-colors hover:text-white" itemprop="item">
						<span itemprop="name">Resources</span>
					</a>
					<meta itemprop="position" content="1" />
				</li>
				<span aria-hidden="true">/</span>
				<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
					<span class="font-medium text-white" itemprop="name" aria-current="page">{category.title}</span>
					<meta itemprop="position" content="2" />
				</li>
			</ol>
		</nav>

		<header class="mb-8">
			<div>
				<h1 class="flex flex-wrap items-center gap-2 text-white">
					<span class="font-mono text-3xl font-semibold">/{category.title}</span>
					<span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-1 text-xs font-medium text-neutral-300">
						{categoryItems.length} resources
					</span>
				</h1>
				<p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-300">
					{category.description}
				</p>
			</div>
		</header>

		<FilterBar allResources={categoryItems} activeFilters={activeFilters} />

		<section class="mb-20" data-category-section>
			<div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
				{categoryItems.map((item) => (
					<ResourceCard
						name={item.name}
						description={item.description}
						iconUrl={item.iconUrl || ""}
						categorySlug={category.categorySlug}
						sponsored={item.sponsored}
						prompt={item.prompt}
						skill={item.skill}
						badges={item.badges}
						techStack={item.techStack}
						features={item.features}
						pricing={item.pricing}
						integrations={item.integrations}
						tags={item.tags}
					/>
				))}
			</div>
		</section>
		</div>
	</main>
</Layout>
