---
import ResourceCard from './Resource-Card.astro';

interface Props {
  title: string;
  description: string;
  items: Array<{
    name: string;
    description: string;
    link: string;
    iconUrl: string;
    sponsored?: "small" | "big";
    prompt?: string;
    badges?: {
      featured?: boolean;
      bestseller?: boolean;
      verified?: boolean;
      new?: boolean;
    };
    techStack?: string[];
    features?: string[];
    pricing?: {
      type: 'free' | 'paid' | 'freemium' | 'byok' | 'top-up';
    };
    integrations?: string[];
    tags?: string[];
  }>;
  categorySlug: string;
}

const { title, description, items, categorySlug } = Astro.props;

const filteredItems = items.filter(item => !item.sponsored || item.sponsored === "small");
---

<section class="scroll-mt-24 space-y-5" data-category-section>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h2 class="flex flex-wrap items-center gap-2 text-white">
        <span class="font-mono text-xl font-semibold">/{title}</span>
        <span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-1 text-xs font-medium text-neutral-300">
          {filteredItems.length} resources
        </span>
      </h2>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-300">
        {description}
      </p>
    </div>
    <a href={`/category/${categorySlug}/`} class="inline-flex h-9 items-center rounded-lg border border-white/10 px-3 text-sm font-medium text-neutral-300 transition-colors hover:border-indigo-300/40 hover:text-white">
      View category
    </a>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    {filteredItems.map((item) => (
      <ResourceCard
        name={item.name}
        description={item.description}
        iconUrl={item.iconUrl || ""}
        categorySlug={categorySlug}
        sponsored={item.sponsored}
        prompt={item.prompt}
        badges={item.badges}
        techStack={item.techStack}
        features={item.features}
        pricing={item.pricing}
        integrations={item.integrations}
        tags={item.tags}
      />
    ))}
  </div>
</section> 
