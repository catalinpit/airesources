---
import Button from './Button.astro';
import LogoIcon from '../icons/LogoIcon.astro';
import CategoryDropdown from './CategoryDropdown.astro';
---

<header class="sticky top-0 z-40 border-b border-white/[0.06] bg-[linear-gradient(180deg,#0f101b_0%,#131422_100%)]">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4 px-4 sm:px-6 lg:px-8" aria-label="Primary">
    <a href="/" class="flex min-w-0 items-center gap-2">
      <LogoIcon class="h-7 w-7 flex-shrink-0 text-white" />
      <span class="hidden truncate text-base font-semibold text-white sm:inline">AI Resources</span>
    </a>
    <div class="flex items-center gap-2 sm:gap-3">
      <CategoryDropdown />
      <Button href="https://github.com/catalinpit/airesources" class="h-9 rounded-lg px-3 text-sm sm:px-4">
        <span class="hidden sm:inline">Submit Tool</span>
        <span class="sm:hidden">Submit</span>
      </Button>
    </div>
  </nav>
</header>
