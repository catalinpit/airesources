---
interface Props {
  title: string;
  description: string;
  stats?: {
    label: string;
    value: string | number;
  }[];
  highlights?: {
    title: string;
    count: number;
    href: string;
  }[];
}

const { title, description, stats, highlights = [] } = Astro.props;
---

<section class="text-white">
	<div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-18 lg:px-8">
		<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
			<div class="max-w-4xl">
				<div class="mb-5 inline-flex items-center gap-2 rounded-full border border-indigo-300/20 bg-indigo-300/10 px-3 py-1 text-xs font-medium text-indigo-100">
					<span class="h-1.5 w-1.5 rounded-full bg-indigo-300 shadow-[0_0_16px_rgba(165,180,252,0.8)]"></span>
					Curated AI index
				</div>
				<h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-6xl">
					{title}
				</h1>
				<p class="mt-5 max-w-2xl text-lg leading-8 text-neutral-300">
					{description}
				</p>

				{stats && (
					<div class="mt-7 flex flex-wrap gap-3 text-sm">
						{stats.map((stat) => (
							<div class="inline-flex items-baseline gap-2 rounded-lg border border-white/10 bg-white/[0.04] px-3 py-2">
								<span class="font-semibold text-neutral-100">{stat.value}</span>
								<span class="text-neutral-300">{stat.label}</span>
							</div>
						))}
					</div>
				)}
			</div>

			{highlights.length > 0 && (
				<div class="pt-1 lg:border-l lg:border-white/10 lg:pl-6 lg:pt-0">
					<div class="mb-3 flex items-center justify-between gap-4">
						<p class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-neutral-300">
							/Top categories
						</p>
						<div class="h-px flex-1 bg-gradient-to-r from-indigo-300/35 to-transparent"></div>
					</div>
					<div class="space-y-1">
						{highlights.map((item) => (
							<a
								href={item.href}
								class="group flex items-center justify-between gap-4 rounded-lg px-2 py-2 transition-colors hover:bg-white/[0.05]"
							>
								<span class="truncate text-sm font-medium text-neutral-200 transition-colors group-hover:text-white">
									/{item.title}
								</span>
								<span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-1 text-xs font-medium text-neutral-300">
									{item.count}
								</span>
							</a>
						))}
					</div>
				</div>
			)}
		</div>
	</div>
</section>
