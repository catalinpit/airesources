---
import { getCollection } from 'astro:content';
import GitHubIcon from './icons/GitHubIcon.astro';
import TwitterIcon from './icons/TwitterIcon.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
const isHomepage = currentPath === '/' || currentPath === '';

const categories = await getCollection('categories');
const currentYear = new Date().getFullYear();
---

<footer class="mt-0 border-t border-white/10 bg-[#090a0f]">
  <div class="container mx-auto px-4 py-6">
    <div class="flex flex-col items-center gap-4">
      {!isHomepage && (
        <nav aria-label="Footer categories">
          <div class="flex flex-wrap justify-center gap-x-4 gap-y-2 text-xs text-neutral-500">
            <a
              href="/"
              class="transition-colors hover:text-neutral-300"
            >
              All
            </a>
            {categories.map((category) => (
              <a
                href={`/category/${category.data.categorySlug}/`}
                class="transition-colors hover:text-neutral-300"
              >
                {category.data.title}
              </a>
            ))}
          </div>
        </nav>
      )}
      <div class="flex flex-col items-center justify-center gap-4 text-xs text-neutral-500 sm:flex-row">
        <span>© {currentYear} AI Resources</span>
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/catalinpit"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-neutral-300"
            aria-label="GitHub"
          >
            <GitHubIcon class="w-4 h-4" />
          </a>
          <a
            href="https://x.com/catalinmpit"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-neutral-300"
            aria-label="X (Twitter)"
          >
            <TwitterIcon class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
